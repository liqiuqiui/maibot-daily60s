{
  "manifest_version": 2,
  "version": "1.0.0",
  "name": "每日速读插件",
  "description": "每日定时推送新闻速读等内容，支持多数据源和关键词触发",
  "author": {
    "name": "liqiuqiu",
    "url": "https://github.com/liqiuqiui/maibot-daily60s"
  },
  "license": "GPL-v3.0-or-later",
  "urls": {
    "repository": "https://github.com/liqiuqiui/maibot-daily60s",
    "homepage": "https://github.com/liqiuqiui/maibot-daily60s",
    "documentation": "https://github.com/liqiuqiui/maibot-daily60s",
    "issues": "https://github.com/liqiuqiui/maibot-daily60s/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "send.image",
    "config.get",
    "chat.get_stream_by_group_id"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": ["zh-CN"]
  },
  "id": "maibot-team.daily60s-plugin"
}
