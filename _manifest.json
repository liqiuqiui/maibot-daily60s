{
  "manifest_version": 2,
  "version": "1.0.0",
  "name": "每日信息速递",
  "description": "每日定时推送新闻速递等内容，支持多数据源和关键词触发",
  "author": {
    "name": "liqiuqiu",
    "url": "https://github.com/liqiuqiui/maibot-daily60s"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/liqiuqiui/maibot-daily60s",
    "homepage": "https://github.com/liqiuqiui/maibot-daily60s",
    "documentation": "https://github.com/liqiuqiui/maibot-daily60s",
    "issues": "https://github.com/liqiuqiui/maibot-daily60s/issues"
  },
  "host_application": {
    "min_version": "1.0.9",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.6.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "send.image",
    "config.get",
    "chat.get_group_streams",
    "chat.get_private_streams",
    "chat.get_stream_by_group_id",
    "chat.get_stream_by_user_id",
    "render.html2png"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": ["zh-CN"]
  },
  "id": "liqiuqiui.daily60s-plugin",
  "plugin_type": "tool"
}
